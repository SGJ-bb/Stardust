<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application
        android:name=".CompanionApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Companion">

        <activity
            android:name=".ui.ActivationActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <activity
            android:name=".ui.HomeActivity"
            android:exported="true"
            android:theme="@style/Theme.Companion">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SplashActivity"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".ui.WebTestActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.SettingsActivity"
            android:label="设置"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.MemoryActivity"
            android:label="记忆管理"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.ModelManagerActivity"
            android:label="Live2D模型管理"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.ModelSettingsActivity"
            android:label="模型设置"
            android:parentActivityName=".ui.ModelManagerActivity" />

        <activity
            android:name=".ui.DiaryActivity"
            android:label="星尘的日记"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.AlarmActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <activity
            android:name=".ui.ProfileActivity"
            android:label="AI 档案"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.AchievementActivity"
            android:label="成就殿堂"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.MemoryPoolActivity"
            android:label="记忆池"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.PersonaEditorActivity"
            android:label="角色设定"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.ModelAdjustActivity"
            android:label="调整模型"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity android:name="com.aicompanion.sticker.StickerActivity" android:theme="@style/Theme.AppCompat.Light.DarkActionBar" />
        <activity android:name="com.aicompanion.moments.MomentsActivity" android:theme="@style/Theme.AppCompat.Light.DarkActionBar" />

        <activity
            android:name="com.aicompanion.wakeup.WakeUpActivity"
            android:label="定时唤醒"
            android:theme="@style/Theme.Companion" />

        <activity
            android:name="com.aicompanion.ui.SkinShopActivity"
            android:label="皮肤商店"
            android:theme="@style/Theme.Companion" />

        <activity
            android:name="com.aicompanion.groupchat.GroupChatListActivity"
            android:label="群聊"
            android:theme="@style/Theme.Companion" />

        <activity
            android:name="com.aicompanion.groupchat.GroupChatActivity"
            android:label="群聊"
            android:theme="@style/Theme.Companion" />

        <activity
            android:name="com.aicompanion.ui.LocalModelActivity"
            android:label="本地模型"
            android:theme="@style/Theme.Companion" />

        <activity
            android:name="com.aicompanion.ui.VirtualWorldActivity"
            android:label="虚拟世界"
            android:parentActivityName=".ui.SettingsActivity"
            android:theme="@style/Theme.Companion" />

        <service
            android:name=".services.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <service
            android:name=".services.BackgroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <receiver
            android:name=".wakeup.WakeUpReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".wakeup.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".action.AIActionManager$ReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <service
            android:name=".screen.ScreenRecognitionService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
