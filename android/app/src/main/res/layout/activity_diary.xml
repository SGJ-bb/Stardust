<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#161b22">

        <ImageButton
            android:id="@+id/btn_diary_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            app:tint="#8899cc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="我的日记"
            android:textColor="#e6edf3"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btn_search_diary"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="搜索"
            app:tint="#8899cc" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_diary_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:paddingHorizontal="12dp"
        android:background="#161b22"
        android:visibility="gone">

        <EditText
            android:id="@+id/et_search_diary"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="搜索日记..."
            android:textColorHint="#667788"
            android:textColor="#c9d1d9"
            android:textSize="13sp"
            android:background="@drawable/bg_model_path"
            android:paddingHorizontal="12dp"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginStart="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_mood_all"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="全部"
                android:checkable="true"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_mood_happy"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🥰"
                android:checkable="true"
                android:layout_marginStart="4dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_mood_calm"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="😌"
                android:checkable="true"
                android:layout_marginStart="4dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/listview_diaries"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#1c2128"
            android:dividerHeight="1dp"
            android:padding="8dp"
            android:background="#0d1117" />

        <TextView
            android:id="@+id/tv_diary_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="还没有日记呢\n多聊聊天，晚上就会生成日记啦~"
            android:textColor="#667788"
            android:textSize="14sp"
            android:visibility="gone"
            android:lineSpacingExtra="6dp" />
    </FrameLayout>
</LinearLayout>