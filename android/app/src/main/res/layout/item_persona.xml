<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#1a1a38"
    app:contentPadding="14dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#33c4b5fd">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_persona_avatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1e1e44"
            app:strokeWidth="2dp"
            app:strokeColor="#9c7cff">

            <ImageView
                android:id="@+id/iv_persona_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_avatar_default_ai" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_persona_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#e0e0f0"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_persona_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8899bb"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="3dp" />

            <TextView
                android:id="@+id/tv_last_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#556677"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_edit_persona"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_edit"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#667788"
            android:contentDescription="编辑" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
