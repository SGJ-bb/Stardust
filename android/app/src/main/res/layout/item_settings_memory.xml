<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  AI 功能与记忆"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8899dd"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_settings_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_persona_editor"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="角色设定"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#667eea"
                app:cornerRadius="12dp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_memories"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="记忆管理"
                android:textSize="14sp"
                android:textColor="#667eea"
                app:strokeColor="#667eea"
                app:cornerRadius="12dp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_all_memories"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="清空记忆"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#cc3344"
                app:cornerRadius="12dp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_chat_history"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="清空聊天记录"
                android:textSize="14sp"
                android:textColor="#cc3344"
                app:strokeColor="#cc3344"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
