<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0c29"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#00ffffff"
            android:elevation="0dp"
            app:title="AI 档案"
            app:titleTextColor="#e8e8f0"
            app:titleTextAppearance="@style/ToolbarTitleStyle"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="#c4b5fd"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1a1a3e"
                    app:strokeWidth="2dp"
                    app:strokeColor="#667eea">

                    <ImageView
                        android:id="@+id/iv_ai_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_default_ai"
                        android:contentDescription="AI头像" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击更换"
                    android:textSize="10sp"
                    android:textColor="#667eea"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_ai_name_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="星尘"
                    android:textSize="13sp"
                    android:textColor="#e8e8f0"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="56dp"
                android:background="#22c4b5fd" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1a1a3e"
                    app:strokeWidth="2dp"
                    app:strokeColor="#ff6b9d">

                    <ImageView
                        android:id="@+id/iv_user_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_default_user"
                        android:contentDescription="用户头像" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击更换"
                    android:textSize="10sp"
                    android:textColor="#667eea"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_user_name_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主人"
                    android:textSize="13sp"
                    android:textColor="#e8e8f0"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1a1a3e"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2a2a5a">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤ 好感度"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#ff6b9d" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_affection_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="朋友"
                        android:textSize="13sp"
                        android:textColor="#c4b5fd" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_affection_profile"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#ff6b9d"
                    android:progressBackgroundTint="#22ff6b9d" />

                <TextView
                    android:id="@+id/tv_affection_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="50 / 100"
                    android:textSize="11sp"
                    android:textColor="#8899cc"
                    android:gravity="end"
                    android:layout_marginTop="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tv_days_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="相伴 1 天"
                        android:textSize="12sp"
                        android:textColor="#8899cc"
                        android:gravity="center" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:background="#22c4b5fd" />

                    <TextView
                        android:id="@+id/tv_ach_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 成就"
                        android:textSize="12sp"
                        android:textColor="#8899cc"
                        android:gravity="center" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:background="#22c4b5fd" />

                    <TextView
                        android:id="@+id/tv_diary_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 日记"
                        android:textSize="12sp"
                        android:textColor="#8899cc"
                        android:gravity="center" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  已解锁的成就"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#8899dd"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1a1a3e"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2a2a5a">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_achievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:nestedScrollingEnabled="false" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  值得铭记的事情"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ff6b9d"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_moments_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 正在了解你...\n多聊聊天，AI会记住关于你的珍贵瞬间"
            android:textSize="13sp"
            android:textColor="#667788"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/container_moments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />
    </LinearLayout>
</ScrollView>