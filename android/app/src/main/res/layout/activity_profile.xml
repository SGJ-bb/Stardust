<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0c29"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#00ffffff"
            android:elevation="0dp"
            app:title="AI 档案"
            app:titleTextColor="#e8e8f0"
            app:titleTextAppearance="@style/ToolbarTitleStyle"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="#c4b5fd"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="32dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1a1a3e"
                    app:strokeWidth="2dp"
                    app:strokeColor="#667eea">

                    <ImageView
                        android:id="@+id/iv_ai_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_default_ai"
                        android:contentDescription="AI头像" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击更换"
                    android:textSize="10sp"
                    android:textColor="#667eea"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_ai_name_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="星尘"
                    android:textSize="13sp"
                    android:textColor="#e8e8f0"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_affection_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="朋友"
                    android:textSize="16sp"
                    android:textColor="#ff6b9d"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progress_affection_profile"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="120dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#ff6b9d"
                    android:progressBackgroundTint="#22ff6b9d" />

                <TextView
                    android:id="@+id/tv_affection_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 / 100"
                    android:textSize="11sp"
                    android:textColor="#8899cc"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="32dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1a1a3e"
                    app:strokeWidth="2dp"
                    app:strokeColor="#ff6b9d">

                    <ImageView
                        android:id="@+id/iv_user_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_default_user"
                        android:contentDescription="用户头像" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击更换"
                    android:textSize="10sp"
                    android:textColor="#ff6b9d"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_user_name_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主人"
                    android:textSize="13sp"
                    android:textColor="#e8e8f0"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1a1a3e"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2a2a5a">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 相遇数据"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#9c7cff"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="8dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/tv_stat_total_msgs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="#9c7cff"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 消息"
                            android:textSize="10sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="8dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/tv_stat_chat_days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="#64ffda"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 天数"
                            android:textSize="10sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="8dp"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/tv_stat_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textColor="#ff6b9d"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 连续"
                            android:textSize="10sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="6dp"
                        android:layout_marginEnd="3dp">

                        <TextView
                            android:id="@+id/tv_stat_user_msgs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="#ff6b9d"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✍️ 我发的"
                            android:textSize="9sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="6dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp">

                        <TextView
                            android:id="@+id/tv_stat_ai_msgs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="#667eea"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖 TA回的"
                            android:textSize="9sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="6dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp">

                        <TextView
                            android:id="@+id/tv_stat_stickers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="#ffb347"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😄 表情包"
                            android:textSize="9sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="6dp"
                        android:layout_marginStart="3dp">

                        <TextView
                            android:id="@+id/tv_stat_words"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="#e8a0bf"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📝 字数"
                            android:textSize="9sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="6dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/tv_stat_avg_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textColor="#7fdbda"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📈 日均"
                            android:textSize="9sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_edit_moment"
                        android:padding="6dp"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/tv_stat_peak_hour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="16sp"
                            android:textColor="#c4b5fd"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌙 活跃"
                            android:textSize="9sp"
                            android:textColor="#8899bb" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1a1a3e"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2a2a5a">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_days_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="相伴 1 天"
                    android:textSize="12sp"
                    android:textColor="#8899cc"
                    android:gravity="center" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#22c4b5fd" />

                <TextView
                    android:id="@+id/tv_ach_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 成就"
                    android:textSize="12sp"
                    android:textColor="#8899cc"
                    android:gravity="center" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#22c4b5fd" />

                <TextView
                    android:id="@+id/tv_diary_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 日记"
                    android:textSize="12sp"
                    android:textColor="#8899cc"
                    android:gravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  🏆 已解锁的成就"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#8899dd"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1a1a3e"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2a2a5a">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_achievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:nestedScrollingEnabled="false" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  💫 值得铭记的事情"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ff6b9d"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_moments_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 正在了解你...\n多聊聊天，AI会记住关于你的珍贵瞬间"
            android:textSize="13sp"
            android:textColor="#667788"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/container_moments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  ⭐ 收藏的消息"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffb347"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_favorites_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="还没有收藏任何消息\n长按聊天气泡可以收藏哦~"
            android:textSize="13sp"
            android:textColor="#667788"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/container_favorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />
    </LinearLayout>
</ScrollView>
