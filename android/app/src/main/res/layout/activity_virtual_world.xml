<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f0c29">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#00ffffff"
        android:elevation="0dp"
        app:title="🌍 虚拟世界"
        app:titleTextColor="#e8e8f0"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:navigationIconTint="#c4b5fd" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/layout_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_time_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1a1a3e"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#3a3a6e">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⏱️ 虚拟时间"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#9c7cff" />

                        <TextView
                            android:id="@+id/tv_simulation_status"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="⏸ 已暂停"
                            android:textSize="11sp"
                            android:textColor="#8899bb"
                            android:background="@drawable/bg_edit_moment" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp"
                        android:gravity="center">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#12122e">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/tv_virtual_day"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="第1天"
                                    android:textSize="20sp"
                                    android:textColor="#64ffda"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.02" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📅 虚拟日期"
                                    android:textSize="9sp"
                                    android:textColor="#667788"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#12122e">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/tv_virtual_hour"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="08:00"
                                    android:textSize="20sp"
                                    android:textColor="#667eea"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.02" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🕐 虚拟时刻"
                                    android:textSize="9sp"
                                    android:textColor="#667788"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#12122e">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/tv_time_ratio"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1x"
                                    android:textSize="20sp"
                                    android:textColor="#ff6b9d"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.02" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⚡ 时间倍率"
                                    android:textSize="9sp"
                                    android:textColor="#667788"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <TextView
                            android:id="@+id/tv_location"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📍 起始之地"
                            android:textSize="12sp"
                            android:textColor="#c4b5fd" />

                        <TextView
                            android:id="@+id/tv_weather"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️ 晴朗"
                            android:textSize="12sp"
                            android:textColor="#ffb347" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_stop"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="▶ 开始推演"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="23dp"
                    app:backgroundTint="#667eea"
                    android:textColor="#ffffff" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tick_now"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="⏩ 立即推演"
                    android:textSize="14sp"
                    app:cornerRadius="23dp"
                    app:strokeColor="#667eea"
                    app:strokeWidth="1.5dp"
                    app:backgroundTint="@android:color/transparent"
                    android:textColor="#aabbdd"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1a1a3e"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#3a3a6e">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️ 推演设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#9c7cff"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="时间倍率"
                            android:textSize="14sp"
                            android:textColor="#c8c8e0" />

                        <Spinner
                            android:id="@+id/spinner_time_ratio"
                            android:layout_width="130dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_edit_moment"
                            android:popupBackground="#1a1a3e" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="推演间隔"
                            android:textSize="14sp"
                            android:textColor="#c8c8e0" />

                        <Spinner
                            android:id="@+id/spinner_tick_interval"
                            android:layout_width="130dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_edit_moment"
                            android:popupBackground="#1a1a3e" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="群聊推演"
                            android:textSize="14sp"
                            android:textColor="#c8c8e0" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_group_sim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="#667eea"
                            app:trackTint="#334466" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="剧情配图"
                            android:textSize="14sp"
                            android:textColor="#c8c8e0" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_image_gen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="#667eea"
                            app:trackTint="#334466" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_world"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="📝 编辑世界观"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="#9c7cff"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@android:color/transparent"
                android:textColor="#c4b5fd"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_personas"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="👥 选择角色"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="#64ffda"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@android:color/transparent"
                android:textColor="#64ffda"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_upload_image"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="📷 上传图片"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="#ff6b9d"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@android:color/transparent"
                android:textColor="#ff6b9d"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tick_index"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="📋 推演索引"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="#ffb347"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@android:color/transparent"
                android:textColor="#ffb347"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <HorizontalScrollView
                android:id="@+id/scroll_uploaded_images"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layout_uploaded_images"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_story_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📖 剧情推演记录"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#9c7cff"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1a1a3e"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#3a3a6e">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_story"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:maxHeight="400dp" />

                    <TextView
                        android:id="@+id/tv_story_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="还没有推演记录\n点击「开始推演」启动虚拟世界"
                        android:textSize="13sp"
                        android:textColor="#667788"
                        android:gravity="center"
                        android:padding="28dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_world"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🔄 重置世界"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="#FF5252"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@android:color/transparent"
                android:textColor="#FF5252"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
