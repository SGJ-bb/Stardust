<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  屏幕识别配置"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8899dd"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_settings_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="屏幕识别"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_screen_recognition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="屏幕识别 API 地址"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeColor="#667eea"
                app:hintTextColor="#667eea"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_screen_api_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#d0d0e0"
                    android:textColorHint="#667788" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="模型名称"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeColor="#667eea"
                app:hintTextColor="#667eea"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_screen_model"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#d0d0e0"
                    android:textColorHint="#667788" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="简单模式"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_simple_screen_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
