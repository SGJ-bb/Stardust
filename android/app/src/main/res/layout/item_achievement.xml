<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_achievement_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="🏆"
            android:textSize="28sp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_achievement_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成就名称"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#e6edf3" />

            <TextView
                android:id="@+id/tv_achievement_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成就描述"
                android:textSize="12sp"
                android:textColor="#8899aa"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <ProgressBar
                    android:id="@+id/progress_achievement_item"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tv_achievement_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1a2030"
        android:layout_marginTop="8dp" />
</LinearLayout>