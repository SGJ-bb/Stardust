<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="64sp"
            android:layout_marginTop="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎来到 AI Companion"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请输入以下口令以激活："
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="时光机大人宇宙无敌超级厉害"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#1A1A2E"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/activationInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="请输入口令"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#1A1A2E"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="16dp"
            android:singleLine="true"
            android:imeOptions="actionDone" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="口令不正确，请再想想~"
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/activateBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="激 活"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C4DFF"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
