<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="20dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <View
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_avatar_glow" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="42dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1e1e44"
                    app:strokeWidth="2dp"
                    app:strokeColor="#9c7cff">

                    <ImageView
                        android:id="@+id/iv_persona_avatar_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_avatar_default_ai"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_avatar"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="选择头像"
                android:textSize="12sp"
                android:textColor="#c4b5fd"
                android:layout_marginTop="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="17dp"
                app:strokeColor="#33c4b5fd"
                app:backgroundTint="#1a1a38"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconSize="14dp"
                app:iconTint="#c4b5fd" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_ai_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_gradient"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_section_indicator" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🪄 AI一键生成"
                    android:textSize="13sp"
                    android:textColor="#9c7cff"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ai_generate"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="生成"
                    android:textSize="12sp"
                    android:textColor="#1a1a38"
                    app:backgroundTint="#9c7cff"
                    app:cornerRadius="17dp"
                    app:icon="@android:drawable/ic_menu_set_as"
                    app:iconSize="14dp"
                    app:iconTint="#1a1a38"
                    style="@style/Widget.Material3.Button" />
            </LinearLayout>

            <EditText
                android:id="@+id/et_ai_keywords"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="输入关键词（如：猫娘、傲娇、魔法师），留空则随机生成"
                android:textSize="13sp"
                android:textColor="#e0e0f0"
                android:textColorHint="#556677"
                android:inputType="text"
                android:maxLines="1"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <ProgressBar
                android:id="@+id/progress_ai_generate"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_section_indicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="基本信息"
                android:textSize="13sp"
                android:textColor="#9c7cff"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_persona_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="角色名（必填）"
            android:textSize="15sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="1"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <Spinner
            android:id="@+id/spinner_persona_gender"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:spinnerMode="dropdown" />

        <EditText
            android:id="@+id/et_persona_desc"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="角色简介（一句话概括身份和特点）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="2"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <EditText
            android:id="@+id/et_persona_greeting"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="开场白（第一次见面时说的话）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="2"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_section_indicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户设定"
                android:textSize="13sp"
                android:textColor="#9c7cff"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_user_identity"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="用户身份（如：学生、勇者、旅行者、主人...）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <EditText
            android:id="@+id/et_user_abilities"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="用户能力/特征（如：会魔法、擅长做饭、温柔...）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_user_personality_def"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:hint="用户性格定义（选填）"
            android:textColorHint="#556677"
            app:hintEnabled="true"
            app:boxBackgroundMode="none">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_user_personality_def"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:maxLines="4"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textSize="14sp"
                android:textColor="#e0e0f0"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:lineSpacingExtra="2dp"
                android:background="@null" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_user_personality_def_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="留空则AI将从对话中自动总结"
            android:textSize="12sp"
            android:textColor="#667788"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_section_indicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="性格与风格"
                android:textSize="13sp"
                android:textColor="#9c7cff"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_persona_personality"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="性格描述（如：活泼可爱、傲娇...）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="2"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <EditText
            android:id="@+id/et_persona_speech"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="说话风格（如：喜欢用颜文字...）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="2"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <EditText
            android:id="@+id/et_persona_catchphrases"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="口头禅（每行一个，如：哼\n才不是呢）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <EditText
            android:id="@+id/et_persona_appearance"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="外貌描述（外观特征、穿着、标志特征）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="2"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <EditText
            android:id="@+id/et_persona_preferences"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="喜好（喜欢和讨厌的事物，每行一个）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_section_indicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="世界书设定"
                android:textSize="13sp"
                android:textColor="#9c7cff"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_world_setting"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="世界观设定（角色所处的世界背景、身份地位）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <EditText
            android:id="@+id/et_world_relationship"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="关系设定（与用户的关系、称呼方式）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="2"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <EditText
            android:id="@+id/et_world_rules"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:hint="行为规则（每行一条，角色必须遵守的准则）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_section_indicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="系统提示词"
                android:textSize="13sp"
                android:textColor="#9c7cff"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_persona_prompt"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="系统提示词（可留空，用于精细控制角色行为）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="3dp" />

        <LinearLayout
            android:id="@+id/btn_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_persona"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="删除"
                android:textSize="14sp"
                android:textColor="#8899bb"
                app:backgroundTint="#1a1a38"
                app:strokeColor="#338899bb"
                app:strokeWidth="1dp"
                app:cornerRadius="24dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_persona"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="创建角色"
                android:textSize="15sp"
                android:textColor="#ffffff"
                app:backgroundTint="#9c7cff"
                app:cornerRadius="24dp"
                android:layout_marginStart="8dp"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
