<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  AI 功能"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8899dd"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_settings_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="定时唤醒"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_wake_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_set_wake_time"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="设置唤醒时间"
                    android:textSize="12sp"
                    android:textColor="#667eea"
                    app:strokeColor="#667eea"
                    app:cornerRadius="10dp"
                    android:layout_marginEnd="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_set_wake_message"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="设置唤醒消息"
                    android:textSize="12sp"
                    android:textColor="#7c5cfc"
                    app:strokeColor="#7c5cfc"
                    app:cornerRadius="10dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_wake_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未设置"
                android:textSize="13sp"
                android:textColor="#667788"
                android:layout_marginBottom="14dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2a2a4a"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="虚拟世界"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_virtual_world"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_virtual_world"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="进入虚拟世界"
                android:textSize="12sp"
                android:textColor="#c4b5fd"
                app:strokeColor="#c4b5fd"
                app:cornerRadius="10dp"
                android:layout_marginBottom="14dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2a2a4a"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="图片生成配置"
                android:textSize="14sp"
                android:textColor="#c4b5fd"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="图片生成 API 地址"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeColor="#667eea"
                app:hintTextColor="#667eea"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_image_api_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#d0d0e0"
                    android:textColorHint="#667788" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="图片生成 API Key"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeColor="#667eea"
                app:hintTextColor="#667eea"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_image_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#d0d0e0"
                    android:textColorHint="#667788"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="图片生成模型"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeColor="#667eea"
                app:hintTextColor="#667eea">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_image_model"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#d0d0e0"
                    android:textColorHint="#667788" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
