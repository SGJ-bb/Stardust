<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  用户与交互"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8899dd"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_settings_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="用户 ID"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeColor="#667eea"
                app:hintTextColor="#667eea"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_user_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#d0d0e0"
                    android:textColorHint="#667788" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="离线模式"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_offline_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="接入微信"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_wechat_bind"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="绑定微信"
                    android:textSize="13sp"
                    android:textColor="#07c160"
                    app:cornerRadius="18dp"
                    app:strokeColor="#07c160"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_wechat_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未绑定"
                android:textSize="12sp"
                android:textColor="#667788"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
