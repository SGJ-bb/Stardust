<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_popup_menu"
    android:elevation="12dp"
    android:paddingHorizontal="4dp"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/emoji_love"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="❤️"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_laugh"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😂"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_wow"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😮"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_cry"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😢"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_angry"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="😡"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_thumbsup"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="👍"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_clap"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="👏"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_party"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="🎉"
        android:textSize="22sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/emoji_remove"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="❌"
        android:textSize="16sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>