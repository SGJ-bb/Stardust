<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="4dp"
    android:gravity="start">

    <FrameLayout
        android:id="@+id/frame_ai_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="6dp"
        android:layout_gravity="bottom"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:id="@+id/iv_ai_avatar_chat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_avatar_default_ai" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/bubble_pet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_pet"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_message_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#e8e8e8"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"
                    android:maxWidth="260dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_reaction_badge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-4dp"
                android:layout_marginBottom="-10dp"
                android:gravity="center"
                android:textSize="12sp"
                android:background="@drawable/bg_reaction_badge"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_message_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#999" />

            <TextView
                android:id="@+id/tv_emotion_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#667eea"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_feedback_like"
                android:layout_width="24dp"
                android:layout_height="18dp"
                android:text="👍"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:alpha="0.0" />

            <TextView
                android:id="@+id/btn_feedback_dislike"
                android:layout_width="24dp"
                android:layout_height="18dp"
                android:text="👎"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginStart="2dp"
                android:alpha="0.0" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
