<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#3a3a5a" />

    <LinearLayout
        android:id="@+id/step_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <View
            android:id="@+id/dot_step1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot_active" />

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:background="#3a3a5a"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot_step2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot_inactive" />

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:background="#3a3a5a"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot_step3"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot_inactive" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_step_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="创建群聊"
        android:textSize="20sp"
        android:textColor="#e8e8f8"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:id="@+id/step1_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_member_chip"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Token消耗提醒"
                    android:textSize="14sp"
                    android:textColor="#e8e8f8"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="每个AI角色都会独立调用LLM\n3人群聊 = 每轮3倍Token消耗"
                    android:textSize="12sp"
                    android:textColor="#8899bb"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="群聊名称"
            android:textSize="13sp"
            android:textColor="#9c7cff"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_group_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="给群聊起个名字吧"
            android:textSize="15sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:inputType="text"
            android:maxLines="1"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="群聊关系设定"
            android:textSize="13sp"
            android:textColor="#9c7cff"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_relationship_setting"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:hint="角色之间的关系（如：A和B是青梅竹马，A暗恋用户...）"
            android:textSize="14sp"
            android:textColor="#e0e0f0"
            android:textColorHint="#556677"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:lineSpacingExtra="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_gen_relationship"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="🪄 AI生成关系"
            android:textSize="12sp"
            android:textColor="#c4b5fd"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="17dp"
            app:strokeColor="#33c4b5fd"
            app:backgroundTint="#1a1a38" />

        <ProgressBar
            android:id="@+id/progress_relationship"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/step2_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择群成员（至少2人）"
            android:textSize="13sp"
            android:textColor="#9c7cff"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_member_select"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="300dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已选择 0 人"
            android:textSize="12sp"
            android:textColor="#667eea"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/step3_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_gradient"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="40sp" />

            <TextView
                android:id="@+id/tv_preview_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="群聊名称"
                android:textSize="18sp"
                android:textColor="#e8e8f8"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tv_preview_members"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成员列表"
                android:textSize="13sp"
                android:textColor="#8899bb"
                android:layout_marginTop="6dp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="上一步"
            android:textSize="15sp"
            android:textColor="#8899bb"
            android:gravity="center"
            android:background="@drawable/bg_btn_secondary"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/spacer_buttons"
            android:layout_width="12dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="下一步"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
