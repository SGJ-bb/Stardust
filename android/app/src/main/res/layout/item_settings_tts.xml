<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  语音合成 TTS"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8899dd"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_settings_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="语音合成"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_tts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TTS 引擎"
                    android:textSize="14sp"
                    android:textColor="#8899bb" />

                <Spinner
                    android:id="@+id/spinner_tts_engine"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#1a1a2e" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_edge_voice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edge 音色（免费）"
                    android:textSize="13sp"
                    android:textColor="#07c160"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_edge_voice"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#1a1a2e"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_cloud_tts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="TTS API 地址"
                    app:boxBackgroundColor="@android:color/transparent"
                    app:boxStrokeColor="#667eea"
                    app:hintTextColor="#667eea"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_tts_api_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#d0d0e0"
                        android:textColorHint="#667788" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="TTS 模型"
                    app:boxBackgroundColor="@android:color/transparent"
                    app:boxStrokeColor="#667eea"
                    app:hintTextColor="#667eea"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_tts_model"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#d0d0e0"
                        android:textColorHint="#667788" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2a2a4a"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TTS 参数调节"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#c4b5fd"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="声调 (Pitch)"
                android:textSize="13sp"
                android:textColor="#8899bb"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <SeekBar
                    android:id="@+id/seek_tts_pitch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="150"
                    android:min="50"
                    android:progress="100"
                    android:progressTint="#667eea"
                    android:thumbTint="#c4b5fd" />

                <TextView
                    android:id="@+id/tv_tts_pitch_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.00"
                    android:textSize="13sp"
                    android:textColor="#c4b5fd"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="语速 (Rate)"
                android:textSize="13sp"
                android:textColor="#8899bb"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <SeekBar
                    android:id="@+id/seek_tts_rate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="200"
                    android:min="50"
                    android:progress="100"
                    android:progressTint="#667eea"
                    android:thumbTint="#c4b5fd" />

                <TextView
                    android:id="@+id/tv_tts_rate_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.00"
                    android:textSize="13sp"
                    android:textColor="#c4b5fd"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2a2a4a"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="情绪分析"
                    android:textSize="15sp"
                    android:textColor="#d0d0e0" />

                <Switch
                    android:id="@+id/switch_emotion_analysis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:trackTint="#667eea"
                    android:thumbTint="#c4b5fd" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
