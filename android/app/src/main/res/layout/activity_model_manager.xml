<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a1a">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1a1a30"
        android:elevation="4dp"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="#aabbdd"
        app:title="Live2D模型管理"
        app:titleTextColor="#ffffff"
        app:titleTextAppearance="@style/ToolbarTitleStyle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1a1a30"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2a2a4a">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前模型"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#c4b5fd" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:id="@+id/iv_current_model_preview"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_model_preview_placeholder"
                            android:scaleType="centerInside"
                            android:contentDescription="模型预览" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/tv_current_model_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PurpleBird"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#e0e0f0" />

                            <TextView
                                android:id="@+id/tv_current_model_desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="紫鸟，默认模型"
                                android:textSize="12sp"
                                android:textColor="#8899aa"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tv_model_version"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cubism 4"
                                android:textSize="12sp"
                                android:textColor="#7c5cfc"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#151530"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#252545">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="如何导入模型？"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#8899dd" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="支持格式：\n1. model3.json（Cubism 3/4，推荐）\n2. model.json（Cubism 2）\n\n导入方式：\n方式A：点击「导入模型」选择单个.json文件\n方式B：将模型文件夹放入手机「Download/Live2D」目录后点击「扫描模型」\n\n模型文件夹需要包含：.model3.json + .moc3/.moc + 纹理图片(png) + physics3.json(可选)"
                        android:textSize="12sp"
                        android:textColor="#6688aa"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_import_model"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="导入模型"
                    android:textSize="14sp"
                    app:cornerRadius="24dp"
                    app:backgroundTint="#667eea"
                    style="@style/Widget.MaterialComponents.Button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_scan_models"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="扫描模型"
                    android:textSize="14sp"
                    app:cornerRadius="24dp"
                    app:strokeColor="#667eea"
                    app:strokeWidth="2dp"
                    app:backgroundTint="@android:color/transparent"
                    android:textColor="#8899cc"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="我的模型库"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#c4b5fd"
        android:padding="16dp"
        android:paddingBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_models"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/tv_empty_models"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="暂无其他模型\n点击导入添加新皮套"
        android:textColor="#556688"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:visibility="gone" />

</LinearLayout>